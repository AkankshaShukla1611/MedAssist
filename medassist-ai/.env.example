# Copy this file to .env and fill in real values.
# NEVER commit the real .env file — add it to .gitignore.

# --- App ---
ENV=development
API_PORT=8000

# --- Database ---
DATABASE_URL=postgresql+psycopg2://medassist:medassist@db:5432/medassist

# --- JWT / Auth ---
# Generate a strong secret, e.g.: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Embedding / LLM (swappable without code changes) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_PROVIDER=ollama
LLM_MODEL=mistral
LLM_BASE_URL=http://ollama:11434
LLM_TIMEOUT_SECONDS=120

# --- RAG tuning ---
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K_RETRIEVE=10
TOP_K_RERANK=5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Storage ---
FAISS_PATH=/app/vector_store/index.faiss
FAISS_METADATA_PATH=/app/vector_store/metadata.json
UPLOAD_FOLDER=/app/uploads
MAX_UPLOAD_SIZE_MB=25

# --- Security ---
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=10/minute
CORS_ORIGINS=["http://localhost:5173"]
FRONTEND_URL=http://localhost:5173
