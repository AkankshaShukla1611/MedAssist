# Copy this file to .env and fill in real values.
# NEVER commit the real .env file — add it to .gitignore.
#
# This file is kept in sync with app/core/config.py's actual Settings
# fields — if you add a setting there, add it here too (a stabilization
# pass on this project found this file drifting out of sync with the real
# config across several build phases; don't let it happen again).

# --- App ---
ENV=development
API_PORT=8000

# --- Database ---
DATABASE_URL=postgresql+psycopg2://medassist:medassist@db:5432/medassist

# --- JWT / Auth ---
# Generate a strong secret, e.g.: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Embedding / LLM (swappable without code changes) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_PROVIDER=ollama
LLM_MODEL=mistral
LLM_BASE_URL=http://ollama:11434
LLM_TIMEOUT_SECONDS=120

# --- RAG tuning ---
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K_RETRIEVE=10
TOP_K_RERANK=5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Hybrid retrieval ---
HYBRID_RETRIEVAL_ENABLED=True
RRF_K=60
QUERY_EXPANSION_ENABLED=True
MAX_QUERY_EXPANSION_TERMS=5

# --- Session memory ---
MAX_SESSION_HISTORY_TURNS=5

# --- Confidence calibration weights (should sum to ~1.0) ---
CONFIDENCE_WEIGHT_RETRIEVAL=0.35
CONFIDENCE_WEIGHT_RERANK=0.25
CONFIDENCE_WEIGHT_GENERATION=0.25
CONFIDENCE_WEIGHT_SUPPORT=0.15

# --- Hallucination detection ---
HALLUCINATION_SUPPORT_THRESHOLD=0.35

# --- Storage ---
FAISS_PATH=/app/vector_store/index.faiss
FAISS_METADATA_PATH=/app/vector_store/metadata.json
BM25_INDEX_PATH=/app/vector_store/bm25_index.pkl
UPLOAD_FOLDER=/app/uploads
MAX_UPLOAD_SIZE_MB=25

# --- Security ---
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=10/minute
CORS_ORIGINS=["http://localhost:5173"]
FRONTEND_URL=http://localhost:5173
CSP_POLICY=default-src 'self'; frame-ancestors 'none'; object-src 'none'
ENABLE_PDF_MALWARE_SCAN=True

# --- Redis (cache; also backs Celery broker/result backend below via a
#     different DB index on the SAME Redis instance — see docker-compose.yml) ---
REDIS_URL=redis://redis:6379/0
CACHE_ENABLED=True
CACHE_TTL_EMBEDDING_SECONDS=86400
CACHE_TTL_RETRIEVAL_SECONDS=600
CACHE_TTL_EVALUATION_SECONDS=3600
CACHE_TTL_DOCUMENT_METADATA_SECONDS=300

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
# Set True ONLY in tests — runs tasks synchronously in-process, no broker needed.
CELERY_TASK_ALWAYS_EAGER=False

# --- API versioning ---
API_V1_PREFIX=/api/v1
